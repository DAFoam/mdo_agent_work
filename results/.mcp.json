{
    "mcpServers": {
        "mdo_agent_deck": {
            "type": "stdio",
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "--name", "mdo_agent_deck",
                "--platform", "linux/amd64",
                "-p", "8001:8001",
                "-p", "8002:8002",
                "--mount", "type=bind,src=.,target=/home/dafoamuser/mount",
                "-w", "/home/dafoamuser/mount",
                "dafoam/agent:latest",
                "bash", "-lc",
                "source /home/dafoamuser/dafoam/loadDAFoam.sh && mdo-agent-deck-mcp"
            ]
        }
    }
}
